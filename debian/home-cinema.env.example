# Copy to home-cinema.env, edit values, then run:
#   sudo ./setup-home-cinema.sh
#
# Do not commit home-cinema.env. It can contain Cloudflare tokens.

LAN_IP=192.168.1.10
FEED_BIND_IP=0.0.0.0
ROUTER_IP=192.168.1.1
LOCAL_PROXY_PORT=18080

TUNNEL_NAME=home-cinema
ZONE_NAME=example.com
EMBY_HOSTNAME=emby.example.com
STREAM_HOSTNAME=stream.example.com

EMBY_UPSTREAM=192.168.1.110:8096
STREAM_UPSTREAM=192.168.1.118:8096

# Recommended for a fresh server:
# Create a remotely managed Cloudflare Tunnel in Zero Trust and paste the token.
TUNNEL_TOKEN=

# Optional: leave empty until you are ready to deploy the CrowdSec Cloudflare Workers bouncer.
CLOUDFLARE_API_TOKEN=
START_CLOUDFLARE_BOUNCER=0
